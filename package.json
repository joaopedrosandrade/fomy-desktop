{
  "name": "fomy",
  "productName": "Fomy",
  "version": "1.0.3",
  "description": "Fomy - Gestão para Restaurantes",
  "main": "main.js",
  "author": "Fomy",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "cross-env NODE_ENV=development electron .",
    "postinstall": "node scripts/generate-icon.js",
    "prebuild": "node scripts/generate-icon.js",
    "build": "electron-builder --win --x64 --publish never",
    "build:output": "electron-builder --win --x64 --publish never --config.directories.output=build-output",
    "release": "electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-reload": "^1.5.0",
    "rcedit": "^4.0.1",
    "to-ico": "^1.1.5"
  },
  "build": {
    "appId": "com.fomy.desktop",
    "productName": "Fomy",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload/**/*",
      "ipc/**/*",
      "services/**/*",
      "windows/**/*",
      "renderer/**/*",
      "scripts/powershell/**/*",
      "assets/favicon.ico",
      "assets/icon.png",
      "assets/icon.ico"
    ],
    "asarUnpack": [
      "scripts/powershell/**/*"
    ],
    "afterPack": "./scripts/after-pack.js",
    "extraFiles": [
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "shortcutName": "Fomy"
    },
    "publish": {
      "provider": "github",
      "owner": "joaopedrosandrade",
      "repo": "fomy-desktop",
      "releaseType": "release",
      "vPrefixedTagName": true
    }
  }
}
